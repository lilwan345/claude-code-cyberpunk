  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "Comments",
        "scope": [
          "comment",
          "comment.line",
          "comment.line.double-slash",
          "comment.line.number-sign",
          "comment.line.shebang",
          "comment.block",
          "comment.block.documentation",
          "string.comment",
          "punctuation.definition.comment",
          "punctuation.definition.comment.begin",
          "punctuation.definition.comment.end"
        ],
        "settings": {
          "foreground": "#6b7a99",
          "fontStyle": "italic"
        }
      },
      {
        "name": "Keywords, storage, control flow, modifiers",
        "scope": [
          "keyword",
          "keyword.control",
          "keyword.control.flow",
          "keyword.control.conditional",
          "keyword.control.loop",
          "keyword.control.import",
          "keyword.control.export",
          "keyword.control.from",
          "keyword.control.as",
          "keyword.control.return",
          "keyword.control.trycatch",
          "keyword.control.exception",
          "keyword.control.at-rule",
          "keyword.control.at-rule.media",
          "keyword.control.at-rule.include.scss",
          "keyword.control.at-rule.mixin.scss",
          "keyword.other",
          "keyword.declaration",
          "keyword.var",
          "storage",
          "storage.type",
          "storage.type.function",
          "storage.type.class",
          "storage.type.var",
          "storage.type.let",
          "storage.type.const",
          "storage.type.def",
          "storage.modifier",
          "storage.modifier.async",
          "storage.modifier.access",
          "punctuation.definition.keyword.css"
        ],
        "settings": {
          "foreground": "#ff2e97"
        }
      },
      {
        "name": "Word-like keyword operators (new, typeof, instanceof, in, of, and/or/not)",
        "scope": [
          "keyword.operator.new",
          "keyword.operator.expression",
          "keyword.operator.expression.typeof",
          "keyword.operator.expression.instanceof",
          "keyword.operator.expression.in",
          "keyword.operator.expression.of",
          "keyword.operator.expression.delete",
          "keyword.operator.expression.void",
          "keyword.operator.expression.import",
          "keyword.operator.wordlike",
          "keyword.operator.logical.python"
        ],
        "settings": {
          "foreground": "#ff2e97"
        }
      },
      {
        "name": "Functions, methods, function calls",
        "scope": [
          "entity.name.function",
          "entity.name.function.member",
          "entity.name.method",
          "entity.name.function.call",
          "meta.function-call",
          "meta.function-call.generic",
          "meta.function-call.method",
          "meta.function-call.python",
          "variable.function",
          "support.function",
          "support.function.builtin",
          "support.function.builtin.python",
          "support.function.magic.python",
          "support.function.aggregate.sql",
          "support.function.scalar.sql",
          "support.function.sql",
          "support.function.shell",
          "support.function.builtin.shell",
          "support.function.misc.scss",
          "support.function.css",
          "entity.name.command.shell"
        ],
        "settings": {
          "foreground": "#00eaff"
        }
      },
      {
        "name": "Strings and string content",
        "scope": [
          "string",
          "string.quoted",
          "string.quoted.single",
          "string.quoted.double",
          "string.quoted.triple",
          "string.quoted.other",
          "string.quoted.docstring",
          "string.template",
          "string.unquoted",
          "string.interpolated",
          "meta.string",
          "punctuation.definition.string",
          "punctuation.definition.string.begin",
          "punctuation.definition.string.end",
          "punctuation.definition.string.template",
          "punctuation.definition.string.begin.markdown",
          "string.quoted.double.json",
          "string.quoted.double.shell",
          "string.unquoted.yaml"
        ],
        "settings": {
          "foreground": "#34ffa6"
        }
      },
      {
        "name": "String escape characters and format placeholders",
        "scope": [
          "constant.character.escape",
          "constant.character.escape.backslash",
          "constant.character.string.escape",
          "constant.other.placeholder",
          "constant.other.placeholder.python",
          "string.regexp constant.character.escape"
